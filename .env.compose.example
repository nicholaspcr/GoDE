# Docker Compose environment file
# Copy to .env.compose and fill in real values. Never commit .env.compose.

# Postgres
POSTGRES_USER=gode_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=gode

# JWT — MUST be at least 32 characters and MUST NOT match any known dev value.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
